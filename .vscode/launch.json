{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Watchdog: server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/watchdog",
      "cwd": "${workspaceFolder}",
      "args": ["Server"],
      // "env": {
      //   "APP_ENV": "dev",
      //   "HTTP_ADDR": ":8080",
      //   "DATABASE_DSN": "${workspaceFolder}/watchdog-dev.db",
      //   "API_KEY": "secret-dev-key",
      //   "WORKER_COUNT": "5",
      //   "CHECK_QUEUE_SIZE": "100",
      //   "SCHEDULER_TICK_SECONDS": "5",
      //   "WEBHOOK_ENABLED": "false",
      //   "WEBHOOK_URL": "",
      //   "LOG_LEVEL": "debug"
      // },
      "console": "integratedTerminal"
    },
    {
      "name": "Watchdog CLI: monitor add example",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/watchdog",
      "cwd": "${workspaceFolder}",
      "args": [
        "monitor",
        "add",
        "--name",
        "Example API",
        "--url",
        "https://example.com/health",
        "--method",
        "GET",
        "--interval",
        "60",
        "--timeout",
        "5",
        "--expected-status",
        "200"
      ],
      "env": {
        "WATCHDOG_API_URL": "http://localhost:8080",
        "WATCHDOG_API_KEY": "secret-dev-key"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Watchdog CLI: monitor list",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/watchdog",
      "cwd": "${workspaceFolder}",
      "args": ["monitor", "list"],
      "env": {
        "WATCHDOG_API_URL": "http://localhost:8080",
        "WATCHDOG_API_KEY": "secret-dev-key"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Watchdog CLI: monitor get",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/watchdog",
      "cwd": "${workspaceFolder}",
      "args": ["monitor", "get", "${input:monitorId}"],
      "env": {
        "WATCHDOG_API_URL": "http://localhost:8080",
        "WATCHDOG_API_KEY": "secret-dev-key"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Watchdog CLI: monitor status",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/watchdog",
      "cwd": "${workspaceFolder}",
      "args": ["monitor", "status", "${input:monitorId}"],
      "env": {
        "WATCHDOG_API_URL": "http://localhost:8080",
        "WATCHDOG_API_KEY": "secret-dev-key"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Watchdog CLI: monitor check",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/watchdog",
      "cwd": "${workspaceFolder}",
      "args": ["monitor", "check", "${input:monitorId}"],
      "env": {
        "WATCHDOG_API_URL": "http://localhost:8080",
        "WATCHDOG_API_KEY": "secret-dev-key"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Watchdog CLI: monitor checks",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/watchdog",
      "cwd": "${workspaceFolder}",
      "args": ["monitor", "checks", "${input:monitorId}", "--limit", "10"],
      "env": {
        "WATCHDOG_API_URL": "http://localhost:8080",
        "WATCHDOG_API_KEY": "secret-dev-key"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Watchdog CLI: monitor delete",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/watchdog",
      "cwd": "${workspaceFolder}",
      "args": ["monitor", "delete", "${input:monitorId}"],
      "env": {
        "WATCHDOG_API_URL": "http://localhost:8080",
        "WATCHDOG_API_KEY": "secret-dev-key"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Go: test current package",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "cwd": "${workspaceFolder}",
      "env": {
        "APP_ENV": "test",
        "DATABASE_DSN": "${workspaceFolder}/watchdog-test.db",
        "API_KEY": "secret-dev-key",
        "LOG_LEVEL": "debug"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Go: attach to running process",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": 0
    }
  ],
  "inputs": [
    {
      "id": "monitorId",
      "type": "promptString",
      "description": "Podaj ID monitora"
    }
  ]
}